# Backend
API_HOST=<backend api hostname>
API_PORT=<backend api port>
JWT_SECRET=<my jwt secret>
FRONTEND_URL=<frontend url for cors rules>

# Frontend
BACKEND_API=http://<API_HOST>:<API_PORT>/api/v1
EXPOSED_PORT=<port to be exposed by frontend (compose only)>
POSTHOG_KEY=<posthog project api key>
POSTHOG_HOST=https://eu.i.posthog.com

# Redis Database
REDIS_HOST=<redis instance hostname>
REDIS_PORT=<redis port>
REDIS_USER=<redis user>
REDIS_PASSWORD=<redis password>